<Window x:Class="CustomerSupport.Client.TicketDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ticket Details" Height="700" Width="800" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Information -->
        <Border Grid.Row="0" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Name="TxtTicketNumber" FontSize="18" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock Name="TxtSubject" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <StackPanel Name="SpCreatedInfo" Orientation="Horizontal">
                        <TextBlock Text="Created by: " Foreground="Gray"/>
                        <TextBlock Name="TxtCreatedBy" Margin="0,0,10,0"/>
                        <TextBlock Text="Date: " Foreground="Gray"/>
                        <TextBlock Name="TxtCreatedDate"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <Border Name="BrdrStatus" Padding="10,5" CornerRadius="4" Margin="0,0,0,5">
                        <TextBlock Name="TxtStatus" Foreground="White" FontWeight="Bold"/>
                    </Border>
                    <Border Name="BrdrPriority" Padding="10,5" CornerRadius="4">
                        <TextBlock Name="TxtPriority" Foreground="White" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Description -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Description" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox Name="TxtDescription" IsReadOnly="True" TextWrapping="Wrap" Height="100" VerticalScrollBarVisibility="Auto" Background="#F9F9F9" Padding="5"/>
            <TextBlock Name="TxtAssignedTo" Margin="0,10,0,0" FontStyle="Italic"/>
        </StackPanel>

        <!-- Content Tabs (Comments and History) -->
        <TabControl Grid.Row="2">
            <TabItem Header="Comments">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <ListBox Grid.Row="0" Name="LbComments" BorderThickness="0" Margin="5" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5" Margin="0,2">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding CreatedByUsername}" FontWeight="Bold" TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="{Binding CreatedDate, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Foreground="Gray" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                <Border Visibility="{Binding IsInternal, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#FFE69D" Padding="4,2" CornerRadius="2">
                                                    <TextBlock Text="INTERNAL" FontSize="10" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Grid.Row="1" Text="{Binding CommentText}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="1" Margin="10">
                        <TextBox Name="TxtNewComment" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>
                        <Grid>
                            <CheckBox Name="ChkInternal" Content="Internal Comment" VerticalAlignment="Center" Visibility="Collapsed"/>
                            <Button Content="Post Comment" Name="BtnAddComment" HorizontalAlignment="Right" Width="120" Height="30" Click="BtnAddComment_Click"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="History">
                <ListView Name="LvHistory">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Date" DisplayMemberBinding="{Binding ChangedDate, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Width="140"/>
                            <GridViewColumn Header="From" DisplayMemberBinding="{Binding OldStatus}" Width="100"/>
                            <GridViewColumn Header="To" DisplayMemberBinding="{Binding NewStatus}" Width="100"/>
                            <GridViewColumn Header="By" DisplayMemberBinding="{Binding ChangedByUsername}" Width="120"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
        </TabControl>

        <!-- Admin Actions Section -->
        <Border Grid.Row="3" Name="BrdrAdminActions" Background="#F0F2F5" Padding="15" Margin="0,15,0,0" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Admin Actions" FontWeight="Bold" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Change Status" Margin="0,0,0,5"/>
                        <ComboBox Name="CbChangeStatus" Height="30">
                            <ComboBoxItem Content="Open" Tag="Open"/>
                            <ComboBoxItem Content="In Progress" Tag="InProgress"/>
                            <ComboBoxItem Content="Closed" Tag="Closed"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Assign To" Margin="0,0,0,5"/>
                        <ComboBox Name="CbAssignTo" Height="30" DisplayMemberPath="Username" SelectedValuePath="Id"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="Save Changes" Name="BtnSaveAdmin" Width="120" Height="30" VerticalAlignment="Bottom" Click="BtnSaveAdmin_Click" Background="#1877F2" Foreground="White"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
