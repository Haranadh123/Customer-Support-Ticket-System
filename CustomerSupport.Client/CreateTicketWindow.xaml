<Window x:Class="CustomerSupport.Client.CreateTicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Ticket" Height="450" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Create New Support Ticket" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <TextBlock Text="Subject" Margin="0,0,0,5"/>
            <TextBox Name="TxtSubject" Height="30" Margin="0,0,0,15"/>
            
            <TextBlock Text="Priority" Margin="0,0,0,5"/>
            <ComboBox Name="CbPriority" Height="30" Margin="0,0,0,15">
                <ComboBoxItem Content="Low" Tag="Low"/>
                <ComboBoxItem Content="Medium" Tag="Medium" IsSelected="True"/>
                <ComboBoxItem Content="High" Tag="High"/>
            </ComboBox>
            
            <TextBlock Text="Description" Margin="0,0,0,5"/>
            <TextBox Name="TxtDescription" Height="150" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20"/>
            
            <UniformGrid Columns="2">
                <Button Content="Cancel" Margin="5" Click="BtnCancel_Click"/>
                <Button Content="Submit" Name="BtnSubmit" Margin="5" Click="BtnSubmit_Click" Background="#1877F2" Foreground="White" FontWeight="Bold"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>
