
## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bin/
obj/
publish/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml

# Build log of MSBuild
*.log

# Visual Studio 2015/2017 cache directories
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/

# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest v2 tests
TestResults/

# Roslyn cache directories
*.Selector.cache

# JetBrains Resharper temp files
_ReSharper*/
*.[Rr]e[Ss]harper.user

# Rider temp files
.idea/

# DotCover temp files
*.dotCover

# AxoCover temp files
.axoCover/*
!.axoCover/settings.json

# Visual Studio Code config files
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Server-side setup files
appsettings.json
appsettings.*.json

# User secrets
secrets.json

# Others
*.tmp
*.bak
*.swp
*.log
*~
